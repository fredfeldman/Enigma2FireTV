<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background_dark">

    <!-- Left panel: bouquet list -->
    <LinearLayout
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/surface_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bouquets"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.03"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_bouquets"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Right panel: channel list -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Toolbar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/surface_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <TextView
                android:id="@+id/tv_bouquet_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_switch_device"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/switch_device"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_epg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/epg_guide"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_recordings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/recordings"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/settings"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_timers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/btn_timers"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_wol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/btn_wol"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:layout_marginEnd="8dp"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_screenshot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button"
                android:text="@string/btn_screenshot"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:padding="8dp"
                android:focusable="true" />

        </LinearLayout>

        <!-- Number jump overlay -->
        <TextView
            android:id="@+id/tv_number_jump"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/surface_dark"
            android:textColor="@color/accent"
            android:textSize="48sp"
            android:textStyle="bold"
            android:padding="24dp"
            android:visibility="gone" />

        <!-- Loading / error states -->
        <ProgressBar
            android:id="@+id/loading_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_error"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/error"
            android:textSize="14sp"
            android:visibility="gone"
            android:padding="16dp" />

        <!-- Channel name filter -->
        <EditText
            android:id="@+id/et_channel_filter"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@color/surface_dark"
            android:hint="@string/hint_channel_filter"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch|flagNoFullscreen"
            android:singleLine="true"
            android:focusable="true" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_channels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
