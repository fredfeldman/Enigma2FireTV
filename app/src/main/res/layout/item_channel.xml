<?xml version="1.0" encoding="utf-8"?>
<!-- Individual channel row in the main channel list -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/selector_channel_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Channel number badge -->
    <TextView
        android:id="@+id/tv_channel_number"
        android:layout_width="36dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginEnd="8dp" />

    <!-- Channel logo / picon -->
    <ImageView
        android:id="@+id/iv_picon"
        android:layout_width="56dp"
        android:layout_height="40dp"
        android:scaleType="fitCenter"
        android:layout_marginEnd="12dp" />

    <!-- Channel name + now playing -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_channel_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_now_playing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Progress bar for current event -->
    <ProgressBar
        android:id="@+id/pb_event_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_marginStart="8dp"
        android:progressTint="@color/accent"
        android:progressBackgroundTint="@color/progress_background" />

    <!-- Recording-in-progress badge -->
    <TextView
        android:id="@+id/tv_rec_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● REC"
        android:textColor="#FFFF4444"
        android:textSize="10sp"
        android:textStyle="bold"
        android:layout_marginStart="4dp"
        android:visibility="gone" />

    <!-- Favorite indicator (visual only – toggled via long-press menu) -->
    <TextView
        android:id="@+id/btn_favorite"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:textSize="20sp"
        android:layout_marginStart="4dp"
        android:focusable="false"
        android:clickable="false"
        android:text="☆"
        android:contentDescription="@string/favorite_toggle" />

</LinearLayout>
